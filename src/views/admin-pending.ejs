<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Admin - Comptes en attente</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <h1>Comptes en attente de validation</h1>
    <ul>
      <% users.forEach(user => { %>
        <li>
          <%= user.username %> - <%= user.email %>
          <form action="/admin/validate/<%= user.id %>" method="POST" style="display:inline;">
            <button type="submit">Valider</button>
          </form>
        </li>
      <% }); %>
    </ul>
  </div>
</body>
</html>